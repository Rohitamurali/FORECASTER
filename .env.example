# Copy this file to .env and set one provider key.
# Environment variables are preferred over API keys saved in SQLite settings.

# Google Gemini API key, usually starts with AIza
GEMINI_API_KEY=AIzaSyBhlj46SRxMarCX9dViI74roK0cFSzuxDs

# OpenAI API key, usually starts with sk-
OPENAI_API_KEY=

# OpenRouter API key, starts with sk-or-
OPENROUTER_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional request controls
LLM_TIMEOUT_SECONDS=30
MAX_LLM_PROMPT_CHARS=20000
LOG_LEVEL=INFO
